<Window x:Class="T4Studio.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:T4Studio.Client"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="T4 Forge - Studio"
        Height="800"
        Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Menu 
            Background="{DynamicResource PrimaryHueMidBrush}"
            Foreground="White"
            Grid.Row="0"
            Grid.ColumnSpan="3">
            
            <MenuItem Header="_Datei">
                <MenuItem Header="_Laden" Click="LoadFile_Click" />
                <MenuItem Header="_Speichern" Click="SaveFile_Click" InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="_Beenden" Click="Exit_Click" />
            </MenuItem>

            <MenuItem Header="_Debug">
                <MenuItem Header="Test: Einfacher Loop" Click="LoadDebugTemplate_Click" Tag="Loop" />
                <MenuItem Header="Test: POCO Klasse" Click="LoadDebugTemplate_Click" Tag="Poco" />
                <MenuItem Header="Test: Fehler-Stresstest" Click="LoadDebugTemplate_Click" Tag="Error" />
            </MenuItem>

            <MenuItem Header="_Themes">
                <MenuItem Header="Dark Mode" Click="ThemeDark_Click" />
                <MenuItem Header="Light Mode" Click="ThemeLight_Click" />
            </MenuItem>
        </Menu>

        <materialDesign:Card Grid.Row="1" Grid.Column="0" Margin="4" UniformCornerRadius="4" VerticalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
                    <StackPanel Margin="4">
                        <TextBlock Text="SNIPPETS" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,5" Foreground="{DynamicResource MaterialDesignBodyLight}"/>

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="Dir" Click="InsertSnippet_Click" ToolTip="T4 Template Directive">
                            <materialDesign:PackIcon Kind="Xml" />
                        </Button>

                        <Separator Margin="8,4" Background="{DynamicResource MaterialDesignDivider}" />

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="Loop" Click="InsertSnippet_Click" ToolTip="For-Schleife (Umschließen)">
                            <materialDesign:PackIcon Kind="Repeat" />
                        </Button>

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="If" Click="InsertSnippet_Click" ToolTip="If-Bedingung (Umschließen)">
                            <materialDesign:PackIcon Kind="CodeBraces" />
                        </Button>

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="Expression" Click="InsertSnippet_Click" ToolTip="Ausdruck">
                            <materialDesign:PackIcon Kind="CodeEqual" />
                        </Button>

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="Comment" Click="InsertSnippet_Click" ToolTip="T4 Kommentar">
                            <materialDesign:PackIcon Kind="CommentText" />
                        </Button>

                        <Separator Margin="8,4" Background="{DynamicResource MaterialDesignDivider}" />

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="Prop" Click="InsertSnippet_Click" ToolTip="C# Property">
                            <materialDesign:PackIcon Kind="AlphaPBox" />
                        </Button>

                        <Button Style="{StaticResource MaterialDesignIconButton}" Tag="Date" Click="InsertSnippet_Click" ToolTip="Datum">
                            <materialDesign:PackIcon Kind="CalendarClock" />
                        </Button>

                    </StackPanel>
                </Border>
                <avalonEdit:TextEditor
                    x:Name="EditorInput"
                    Grid.Column="1"
                    FontFamily="Cascadia Code, Consolas"
                    FontSize="13"
                    Padding="10"
                    ShowLineNumbers="True"
                    TextChanged="EditorInput_TextChanged"
                    Background="Transparent"
                    Foreground="{DynamicResource MaterialDesignBody}"/>
            </Grid>
        </materialDesign:Card>

        <GridSplitter Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Width="4" Background="Transparent"/>

        <materialDesign:Card Grid.Row="1" Grid.Column="2" Margin="4" UniformCornerRadius="4" Background="{DynamicResource MaterialDesignBackground}">
            <avalonEdit:TextEditor
                x:Name="EditorOutput"
                IsReadOnly="True"
                Background="Transparent"
                Padding="10"
                FontFamily="Cascadia Code, Consolas"
                FontSize="13"/>
        </materialDesign:Card>

        <GridSplitter Grid.Row="2" Grid.ColumnSpan="3" Height="4" HorizontalAlignment="Stretch" Background="Transparent"/>

        <materialDesign:Card Grid.Row="3" Grid.ColumnSpan="3" Margin="4" Background="{DynamicResource MaterialDesignCardBackground}">
            <ListView 
                x:Name="ErrorList" 
                Height="150"
                Background="#2D2D2D" 
                Foreground="White"
                Style="{StaticResource MaterialDesignListView}"
                SelectionMode="Single"
                MouseDoubleClick="ErrorList_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Zeile" DisplayMemberBinding="{Binding Line}" Width="50"/>
                        <GridViewColumn Header="Spalte" DisplayMemberBinding="{Binding Column}" Width="50"/>
                        <GridViewColumn Header="Beschreibung" DisplayMemberBinding="{Binding ErrorText}" Width="500"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </materialDesign:Card>

        <StatusBar Grid.Row="4" Grid.ColumnSpan="3" Background="{DynamicResource PrimaryHueDarkBrush}" Foreground="White">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Bereit" />
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
